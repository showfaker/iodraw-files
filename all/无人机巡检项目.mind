expand"},"children":[]},{"data":{"id":"d2ks5mf103c0","created":1720505097659,"text":"曝光偏移值","expandState":"expand"},"children":[]},{"data":{"id":"d2ks6xlehhc0","created":1720505200353,"text":"最大光圈值","expandState":"expand"},"children":[]},{"data":{"id":"d2ks72lwl9s0","created":1720505211267,"text":"曝光模式","expandState":"expand"},"children":[]},{"data":{"id":"d2ks7719hfs0","created":1720505220903,"text":"白平衡模式","expandState":"expand"},"children":[]}]},{"data":{"id":"d2ks1h3cbeg0","created":1720504772611,"text":"照片分析结果","priority":1,"expandState":"collapse"},"children":[{"data":{"id":"d2ks1wpmn3c0","created":1720504806611,"text":"组串编号","expandState":"expand"},"children":[]},{"data":{"id":"d2ks23rdtl40","created":1720504821954,"text":"组串问题等级","expandState":"expand"},"children":[]},{"data":{"id":"d2ks2ai9rzc0","created":1720504836641,"text":"组串热力图","expandState":"expand"},"children":[]},{"data":{"id":"d2ks5vzxew00","created":1720505118513,"text":"组串状态","expandState":"expand"},"children":[]},{"data":{"id":"d2ks670qe740","created":1720505142507,"text":"组串是否修复","expandState":"expand"},"children":[]},{"data":{"id":"d2ks8sdrxls0","created":1720505345736,"text":"操作按钮","expandState":"expand"},"children":[{"data":{"id":"d2ks8xovi5c0","created":1720505357291,"text":"查看","expandState":"expand"},"children":[]},{"data":{"id":"d2ks96non740","created":1720505376810,"text":"删除","expandState":"expand"},"children":[]},{"data":{"id":"d2ks99zg2h40","created":1720505384052,"text":"编辑","expandState":"expand"},"children":[]}]}]}]},{"data":{"id":"d2kpewkda4w0","created":1720497361697,"text":"4.视频管理","expandState":"expand"},"children":[{"data":{"id":"d2ksbqvsjcg0","created":1720505577564,"text":"视屏回访界面","note":"功能描述：回顾已存有的视频，图片预计各类数据。\n执行条件：用户访问视频回放页面，选择想要查看已保存的数据、视频、图片等。\n执行结果：提供历史数据查询、分析和回放功能。","expandState":"collapse"},"children":[{"data":{"id":"d2ksdbeh2s80","created":1720505700594,"text":"编号","expandState":"expand"},"children":[]},{"data":{"id":"d2ksdiqpats0","created":1720505716571,"text":