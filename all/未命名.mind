{"root":{"data":{"id":"d2kmvjzclns0","created":1720490203166,"text":"无人机管理系统"},"children":[{"data":{"id":"d2kmvu4hj4o0","created":1720490225244,"text":"用户登录"},"children":[{"data":{"id":"d2kncx2wodc0","created":1720491563870,"text":"用户身份验证","note":"功能描述：用户输入用户名和密码后，系统通过比对数据库中的信息来验证用户的身份。\n执行条件：用户输入用户名和密码，并点击登录按钮。\n执行结果：如果验证成功，用户将进入系统主界面；如果验证失败，系统将显示错误消息，并允许用户重新输入。"},"children":[{"data":{"id":"d2knguknqgg0","created":1720491871870,"text":"账号错误"},"children":[]}]},{"data":{"id":"d2knd0jt6rs0","created":1720491571422,"text":"用户登录界面"},"children":[]},{"data":{"id":"d2kndmcz9fk0","created":1720491618899,"text":"退出登录"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}